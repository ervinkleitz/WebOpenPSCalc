# Reference nginx site config — copy to /etc/nginx/sites-available/openpscalc
# on the EC2 box during one-time setup, edit server_name/root, then:
#   sudo ln -s /etc/nginx/sites-available/openpscalc /etc/nginx/sites-enabled/openpscalc
#   sudo rm -f /etc/nginx/sites-enabled/default
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name _;  # replace with your domain or EC2 public DNS

    root /home/ubuntu/openpscalc/frontend/dist;  # match EC2_DEPLOY_PATH
    index index.html;

    location /api/ {
        proxy_pass http://127.0.0.1:4000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Stats API sub-paths — proxied to backend. The /stats page itself (no
    # trailing slash) is intentionally excluded so the SPA serves it.
    location /stats/ {
        proxy_pass http://127.0.0.1:4000/stats/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # SPA fallback — React Router routes that aren't real files go to index.html
    location / {
        try_files $uri /index.html;
    }
}
