{
  "name": "open-ps-calc-backend",
  "version": "1.0.0",
  "description": "Backend API for the Open PS Calc damage calculator (Node/Express port of the Python core engine)",
  "main": "src/server.ts",
  "type": "commonjs",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "node --test test/calc-goldens.test.js test/engine-units.test.js",
    "test:gen-goldens": "node test/gen-goldens.js",
    "stats:backfill-regions": "node src/scripts/backfill-regions.js",
    "stats:refilter-bots": "node src/scripts/refilter-bots.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "tsx": "^4.22.4"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
